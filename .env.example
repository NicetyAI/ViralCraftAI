DATABASE_URL=
# Auth.js reads AUTH_SECRET; we fall back to NEXTAUTH_SECRET in code if unset.
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
KIE_API_KEY=

# Demo login after `npm run db:seed` (development default if unset).
DEMO_OWNER_PASSWORD=

# Set to true in production only if you intentionally run `npm run db:seed` (demo owner + workspace).
ALLOW_DEMO_SEED=
